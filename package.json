{
  "name": "agent-watch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3456",
    "dev:server": "tsx server.ts",
    "build": "next build",
    "start": "NODE_ENV=production node server.js",
    "lint": "eslint",
    "test": "vitest",
    "db:reset": "node -e \"const fs=require('fs');const p=require('path').join(process.cwd(),'data','agentwatch.db');[p,p+'-wal',p+'-shm'].forEach(f=>{try{fs.unlinkSync(f);console.log('Deleted',f)}catch{}});console.log('DB reset — will recreate on next request')\"",
    "rebuild-native": "npm rebuild better-sqlite3",
    "postinstall": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@use-gesture/react": "^10.3.1",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.1.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "ws": "^8.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
