# Path to your Claude Code data directory.
# Defaults to ~/.claude (Linux/Mac) or %USERPROFILE%\.claude (Windows).
# Override if Claude is installed in a non-standard location.
# CLAUDE_HOME=~/.claude

# Port the dev/prod server listens on. Defaults to 3456.
# PORT=3456

# Path to the AgentWatch SQLite database file.
# Defaults to <project-root>/data/agentwatch.db.
# CLAUDE_DB_PATH=/custom/path/agentwatch.db
