# ── Windows (PowerShell) — single source ───────────────────────────────────────
# Default setup: running `docker compose up` directly from Windows, no WSL.
# Replace <yourname> with your actual Windows username. Forward slashes required.
CLAUDE_HOME_WINDOWS=C:/Users/<yourname>/.claude
COMPOSE_SOURCES=Windows:/claude-data-windows

# ── macOS / Linux ───────────────────────────────────────────────────────────────
# No config needed — leave CLAUDE_HOME_WINDOWS and COMPOSE_SOURCES unset/commented
# out above. docker compose falls back to CLAUDE_HOME_WSL/CLAUDE_HOME_WINDOWS
# defaulting to ~/.claude, which resolves correctly on macOS/Linux.

# ── Windows + WSL2 (both sources) ────────────────────────────────────────────────
# Only works when docker compose is run FROM a WSL2 terminal — use start.sh
# instead of setting these by hand, it auto-detects both paths:
#
#   bash start.sh
#
# Setting CLAUDE_HOME_WSL here and running `docker compose up` from Windows
# PowerShell will NOT reach your real WSL files — WSL-style paths only resolve
# correctly when compose itself runs inside WSL2. If you're not running from a
# WSL2 terminal, leave CLAUDE_HOME_WSL unset and use the single-source Windows
# config above instead.
#
# COMPOSE_SOURCES=WSL:/claude-data-wsl,Windows:/claude-data-windows
# CLAUDE_HOME_WSL=/home/<yourname>/.claude

# ── Local Node.js dev server ─────────────────────────────────────────────────────
# This file is only for Docker. CLAUDE_HOME_WINDOWS / CLAUDE_HOME_WSL /
# COMPOSE_SOURCES have no effect outside docker compose. For a local Node.js
# dev server instead, copy .env.local.example to .env.local and set CLAUDE_HOME
# there.

# ── Threshold alerts ──────────────────────────────────────────────────────────
# All threshold settings (cost, duration, Teams webhook URL) are configurable
# from the Alerts page in the UI. Env vars below serve as initial defaults.

# Public URL of AgentWatch (used in Teams card links). Match your PORT.
# AGENTWATCH_PUBLIC_URL=http://localhost:3456

# How often to check thresholds (ms). Default 120000 (2 minutes).
# ALERT_CHECK_INTERVAL_MS=120000

# ── General ───────────────────────────────────────────────────────────────────
# Port the server listens on. Defaults to 3456.
PORT=3456
