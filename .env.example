# ── Multi-source configuration (optional) ────────────────────────────────────
# Define named sources so the UI shows a switcher.
# Format: "Label:/container-mount-path,Label2:/container-mount-path2"
# The label becomes the slug used in ?source= query params and DB filenames.
# Example for WSL + Windows on Docker Desktop:
AGENTWATCH_SOURCES=WSL:/claude-data-wsl,Windows:/claude-data-windows

# Host paths to mount into the container (used in docker-compose.yml volumes).
# Windows path to WSL home (Docker Desktop can mount \\wsl$ paths):
CLAUDE_HOME_WSL=\\wsl$\Ubuntu\home\yourname\.claude
# Windows-native Claude home:
CLAUDE_HOME_WINDOWS=C:\Users\yourname\.claude

# ── Single-source fallback (used when AGENTWATCH_SOURCES is not set) ──────────
# Defaults to ~/.claude (Linux/Mac) or %USERPROFILE%\.claude (Windows).
# CLAUDE_HOME=

# ── General ───────────────────────────────────────────────────────────────────
# Port the dev/prod server listens on. Defaults to 3456.
PORT=3456

# Path to the AgentWatch SQLite database file (base path — per-source DBs get
# a suffix, e.g. agentwatch-wsl.db, agentwatch-windows.db).
# CLAUDE_DB_PATH=/custom/path/agentwatch.db
