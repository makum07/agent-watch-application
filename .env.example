# ── Quick start ───────────────────────────────────────────────────────────────
# For WSL + Windows multi-source setup, use start.sh from a WSL2 terminal:
#
#   bash start.sh
#
# start.sh auto-detects your WSL home and Windows username — no path config needed.
# You only need to set PORT and COMPOSE_SOURCES below.

# ── Multi-source configuration ────────────────────────────────────────────────
# Define named sources so the UI shows a source switcher.
# Format: "Label:/container-mount-path,Label2:/container-mount-path2"
COMPOSE_SOURCES=WSL:/claude-data-wsl,Windows:/claude-data-windows

# ── Manual path override (only needed if NOT using start.sh) ──────────────────
# start.sh sets these automatically. Only set manually if you have a non-standard
# .claude location or are running docker compose directly from Windows.
#
# When running docker compose from WSL2 manually:
#   CLAUDE_HOME_WSL=/home/<yourname>/.claude
#   CLAUDE_HOME_WINDOWS=/mnt/c/Users/<yourname>/.claude
#
# When running docker compose from Windows PowerShell (WSL source will NOT work,
# only Windows source works from this context):
#   CLAUDE_HOME_WINDOWS=C:/Users/<yourname>/.claude

# ── Single-source fallback ────────────────────────────────────────────────────
# Used when COMPOSE_SOURCES is not set. Defaults to ~/.claude.
# CLAUDE_HOME=

# ── Threshold alerts ──────────────────────────────────────────────────────────
# All threshold settings (cost, duration, Teams webhook URL) are configurable
# from the Alerts page in the UI. Env vars below serve as initial defaults.

# Public URL of AgentWatch (used in Teams card links). Match your PORT.
AGENTWATCH_PUBLIC_URL=http://localhost:3456

# How often to check thresholds (ms). Default 120000 (2 minutes).
# ALERT_CHECK_INTERVAL_MS=120000

# ── General ───────────────────────────────────────────────────────────────────
# Port the server listens on. Defaults to 3456.
PORT=3456
